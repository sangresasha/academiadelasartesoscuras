const grid = document.getElementById('grid');
let currentFilter = 'todos';

function renderCards(list) {
  grid.innerHTML = '';
  list.forEach(p => {
    const div = document.createElement('div');
    div.className = 'card';
    div.dataset.tipo = p.tipo;
    div.innerHTML = `
      <div class="card-header">
        <div class="char-name">${p.nombre}</div>
        <span class="char-type type-${p.tipo}">${p.tipoLabel}</span>
      </div>
      <div class="char-desc">${p.desc}</div>
      <div class="char-source">◈ ${p.fuente}</div>
    `;
    grid.appendChild(div);
  });
  document.getElementById('count-badge').textContent = list.length + ' personajes';
}

function filterCards() {
  const q = document.getElementById('search').value.toLowerCase();
  const filtered = personajes.filter(p => {
    const matchFilter = currentFilter === 'todos' || p.tipo === currentFilter;
    const matchSearch = !q ||
      p.nombre.toLowerCase().includes(q) ||
      p.desc.toLowerCase().includes(q) ||
      p.tipoLabel.toLowerCase().includes(q);
    return matchFilter && matchSearch;
  });
  renderCards(filtered);
}

function setFilter(tipo, btn) {
  currentFilter = tipo;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  filterCards();
}

