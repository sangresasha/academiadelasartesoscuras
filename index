<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Log de Personajes — El Castillo de Sophia</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=IM+Fell+English+SC&family=Crimson+Pro:ital,wght@0,300;0,400;1,300;1,400&display=swap');

  :root {
    --bg: #0a0608;
    --bg2: #110c0e;
    --card: #160e11;
    --border: #3a1f28;
    --accent: #8b1a2f;
    --gold: #c9933a;
    --gold2: #e8b86d;
    --text: #d4c4bc;
    --muted: #7a6460;
    --tag-bg: #1e1013;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: 16px;
    line-height: 1.7;
    min-height: 100vh;
    background-image:
      radial-gradient(ellipse at 20% 10%, rgba(139,26,47,0.07) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 90%, rgba(201,147,58,0.05) 0%, transparent 60%);
  }

  header {
    text-align: center;
    padding: 3.5rem 2rem 2rem;
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  header::after {
    content: '';
    display: block;
    width: 120px;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold), transparent);
    margin: 1.2rem auto 0;
  }

  h1 {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(1.1rem, 3vw, 1.7rem);
    color: var(--gold2);
    letter-spacing: 0.06em;
    line-height: 1.3;
    text-shadow: 0 0 40px rgba(201,147,58,0.25);
  }

  .subtitle {
    font-family: 'IM Fell English SC', serif;
    color: var(--muted);
    font-size: 0.85rem;
    margin-top: 0.6rem;
    letter-spacing: 0.12em;
  }

  .count-badge {
    display: inline-block;
    background: var(--accent);
    color: #f0cfc0;
    font-family: 'IM Fell English SC', serif;
    font-size: 0.75rem;
    padding: 0.2em 0.9em;
    border-radius: 2px;
    margin-top: 0.7rem;
    letter-spacing: 0.1em;
  }

  .search-wrap {
    max-width: 460px;
    margin: 1.6rem auto 0;
  }

  .search-wrap input {
    width: 100%;
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'Crimson Pro', serif;
    font-size: 0.95rem;
    padding: 0.55rem 1rem;
    border-radius: 3px;
    outline: none;
    transition: border-color 0.2s;
  }
  .search-wrap input:focus { border-color: var(--gold); }
  .search-wrap input::placeholder { color: var(--muted); }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    padding: 1.2rem 1rem 0;
  }

  .filter-btn {
    background: var(--tag-bg);
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: 'IM Fell English SC', serif;
    font-size: 0.75rem;
    padding: 0.3em 0.85em;
    cursor: pointer;
    border-radius: 2px;
    letter-spacing: 0.08em;
    transition: all 0.2s;
  }
  .filter-btn:hover, .filter-btn.active {
    border-color: var(--gold);
    color: var(--gold2);
    background: rgba(201,147,58,0.07);
  }

  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.2rem 4rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.2rem;
  }

  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.3rem 1.4rem;
    position: relative;
    transition: border-color 0.25s, transform 0.2s;
    overflow: hidden;
  }
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.25s;
  }
  .card:hover {
    border-color: #5a2535;
    transform: translateY(-2px);
  }
  .card:hover::before { opacity: 1; }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .char-name {
    font-family: 'IM Fell English SC', serif;
    font-size: 1.05rem;
    color: var(--gold2);
    line-height: 1.2;
  }

  .char-type {
    font-family: 'IM Fell English SC', serif;
    font-size: 0.7rem;
    padding: 0.2em 0.6em;
    border-radius: 2px;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.05em;
  }

  .type-divino   { background: rgba(139,26,47,0.3); color: #d98090; border: 1px solid rgba(139,26,47,0.5); }
  .type-mago     { background: rgba(42,60,100,0.3); color: #88a0d0; border: 1px solid rgba(42,60,100,0.5); }
  .type-caballero{ background: rgba(80,70,20,0.3); color: #d0b860; border: 1px solid rgba(80,70,20,0.5); }
  .type-bruja    { background: rgba(20,80,60,0.3); color: #70c8a0; border: 1px solid rgba(20,80,60,0.5); }
  .type-mortal   { background: rgba(60,50,50,0.3); color: #b0a0a0; border: 1px solid rgba(60,50,50,0.5); }
  .type-bestia   { background: rgba(80,40,10,0.3); color: #d09050; border: 1px solid rgba(80,40,10,0.5); }
  .type-entidad  { background: rgba(60,20,80,0.3); color: #b888d0; border: 1px solid rgba(60,20,80,0.5); }

  .char-desc {
    font-size: 0.93rem;
    color: var(--text);
    line-height: 1.55;
    font-style: italic;
    opacity: 0.9;
  }

  .char-source {
    margin-top: 0.7rem;
    font-size: 0.75rem;
    color: var(--muted);
    font-family: 'IM Fell English SC', serif;
    letter-spacing: 0.05em;
  }

  .hidden { display: none !important; }

  footer {
    text-align: center;
    padding: 2rem;
    color: var(--muted);
    font-size: 0.8rem;
    font-family: 'IM Fell English SC', serif;
    letter-spacing: 0.1em;
    border-top: 1px solid var(--border);
  }
</style>
</head>
